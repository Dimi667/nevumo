{
  "name": "nevumo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:onboarding": "playwright test tests/onboarding-basic.spec.ts",
    "test:smoke": "playwright test tests/onboarding-smoke.spec.ts",
    "test:critical": "playwright test tests/onboarding-critical.spec.ts",
    "validate:onboarding": "npm run test:smoke && npm run build && npm run check-types && echo '✅ Onboarding smoke тестове минават - промяната е готова!'",
    "validate:all": "npm run test:critical && npm run build && npm run check-types && npm run audit && echo '🎉 Всички Nevumo тестове минават - кодът е готов за production!'",
    "validate:quick": "npm run test:smoke && npm run build",
    "test:unit": "jest",
    "test:integration": "playwright test tests/api/",
    "test:e2e": "playwright test tests/e2e/",
    "test:visual": "playwright test --config=playwright-visual.config.ts",
    "test:mobile": "playwright test --device='iPhone 12' --device='Pixel 5'",
    "test:accessibility": "playwright test --config=playwright-a11y.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
