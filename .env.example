# ============================================================
# Nevumo — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ============================================================
# Database (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://nevumo_user:your_password@localhost:5432/nevumo_leads
POSTGRES_DB=nevumo_leads
POSTGRES_USER=nevumo_user
POSTGRES_PASSWORD=your_secure_password

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password   # uncomment if Redis auth is enabled

# ============================================================
# FastAPI Backend
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
SECRET_KEY=your_secret_key_min_32_chars
CORS_ORIGINS=http://localhost:3000

# ============================================================
# Next.js Frontend
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LANG=en

# ============================================================
# Environment
# ============================================================
NODE_ENV=development
PYTHON_ENV=development
