# ============================================================
# Nevumo — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ============================================================
# Database (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://nevumo:nevumo@localhost:5432/nevumo_leads
POSTGRES_DB=nevumo_leads
POSTGRES_USER=nevumo
POSTGRES_PASSWORD=nevumo

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
# FastAPI Backend
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000
# STATIC_FILES_BASE_URL is optional. If not set, the backend will use the request's base_url dynamically.
# Set this to https://your-domain.com in production if you need to override the dynamic detection.
STATIC_FILES_BASE_URL=

# ============================================================
# Next.js Frontend
# ============================================================
# NEXT_PUBLIC_API_URL is used for client-side fetches from the browser.
# Leave empty to use relative URLs (works automatically for localhost, local network, and same-domain production).
# Set to https://api.yourdomain.com only if API is on a different domain in production.
NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_STATIC_URL is used for static file URLs (images, etc).
# In local dev: Leave empty to use runtime detection (works for localhost and local network).
# In production: Set to your CDN/S3 URL (e.g., https://cdn.nevumo.com)
# If not set, static files will use the same domain as the current page.
NEXT_PUBLIC_STATIC_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LANG=en

# ============================================================
# Environment
# ============================================================
PYTHON_ENV=development
