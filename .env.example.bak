# ============================================================
# Nevumo — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ============================================================
# Database (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://nevumo:nevumo@localhost:5432/nevumo_leads
POSTGRES_DB=nevumo_leads
POSTGRES_USER=nevumo
POSTGRES_PASSWORD=nevumo

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
# FastAPI Backend
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000
STATIC_FILES_BASE_URL=http://localhost:8000

# ============================================================
# Next.js Frontend
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LANG=en

# ============================================================
# Environment
# ============================================================
NODE_ENV=development
PYTHON_ENV=development
